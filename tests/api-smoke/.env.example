# Copy this file to tests/api-smoke/.env for local or staging smoke runs.
# tests/api-smoke/.env is ignored by git.

# Required for all smoke runs.
HYPERINDEX_SMOKE_URL=https://api.example.com

# Optional: enable compact request/response logs.
HYPERINDEX_SMOKE_DEBUG=0

# Optional: enable the external label smoke check. The default expectations
# require at least 20 high-quality and 20 standard activity claims from this source.
# HYPERINDEX_SMOKE_EXTERNAL_LABEL_SOURCE_DID=did:plc:external-labeler

# Optional: enable the end-to-end ATProto write-through lifecycle smoke check.
# Use a dedicated disposable account. The test creates, updates, and deletes
# app.certified.actor.profile/self and a generated org.hypercerts.claim.activity.
HYPERINDEX_SMOKE_WRITE_THROUGH=0
HYPERINDEX_SMOKE_ATPROTO_PDS_URL=https://bsky.social
HYPERINDEX_SMOKE_ATPROTO_IDENTIFIER=smoke-account.example.com
HYPERINDEX_SMOKE_ATPROTO_PASSWORD=replace-with-app-password

# Optional write-through polling controls.
HYPERINDEX_SMOKE_WRITE_POLL_TIMEOUT=60s
HYPERINDEX_SMOKE_WRITE_POLL_INTERVAL=2s
